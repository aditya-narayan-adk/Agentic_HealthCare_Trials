# ─── Local development only ────────────────────────────────────────────────────
# Production secrets are in AWS Secrets Manager. This file is for local dev only.
# .env is in .gitignore — never commit this file.
 
# ─── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=
DEBUG=false
 
# ─── Database (local dev uses SQLite, production uses PostgreSQL via Secrets Manager) ──
DATABASE_URL=sqlite+aiosqlite:////db/marketing_platform.db
 
# ─── AWS Bedrock ───────────────────────────────────────────────────────────────
USE_BEDROCK=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
CHAT_MODEL=us.anthropic.claude-haiku-3-5-20241022
 
# ─── Anthropic Direct API (used when USE_BEDROCK=false) ────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
 
# ─── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
 
# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8001
 
# ─── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=/api

# ─── Meta for Developers ──────────────────────────────────────────────────────
# Register at https://developers.facebook.com — add "Facebook Login for Business" + "Marketing API"
# Set META_OAUTH_REDIRECT_URI to your public domain in production (must be HTTPS)
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://yourdomain.com/api/platform-connections/meta/callback

# ─── Open_AI ───────────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
OPENAI_IMAGE_MODEL=gpt-image-1.5